{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "orders-route": {
        "ClusterId": "ordering-cluster",
        "Match": {
          "Path": "/api/v1/orders/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedUser"
      },
      "basket-route": {
        "ClusterId": "ordering-cluster",
        "Match": {
          "Path": "/api/v1/basket/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedUser"
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/v1/inventory/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedUser"
      },
      "payments-route": {
        "ClusterId": "payments-cluster",
        "Match": {
          "Path": "/api/v1/payments/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedUser"
      },
      "fulfillment-route": {
        "ClusterId": "fulfillment-cluster",
        "Match": {
          "Path": "/api/v1/fulfillment/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedUser"
      }
    },
    "Clusters": {
      "ordering-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://ordering-api"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://inventory-api"
          }
        }
      },
      "payments-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://payments-api"
          }
        }
      },
      "fulfillment-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://fulfillment-api"
          }
        }
      }
    }
  }
}

