# E-Commerce Microservices Platform — Environment Variables
# Copy this file to .env and fill in production secrets before running docker compose.
#
# NEVER commit the actual .env file with real secrets to source control.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_dev_password_CHANGE_IN_PROD

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest_dev_password_CHANGE_IN_PROD

# ─── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev_password_CHANGE_IN_PROD

